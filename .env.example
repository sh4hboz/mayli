BIRTHDAY_SMS_TEMPLATE_ID=

# Admin'ni yashirish: maxfiy URL (oxirida slash). Dev'da 'admin/' qoldirsa bo'ladi.
ADMIN_URL=admin/
# Dashboard/admin alohida subdomen. Dev'da bo'sh (host ajratish o'chiq).
DASHBOARD_HOST=

