SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
DATABASE_URL=sqlite:///db.sqlite3
# Production uchun: DATABASE_URL=postgres://user:password@host:5432/dbname
REDIS_URL=redis://127.0.0.1:6379

TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff
TELEGRAM_ADMIN_CHAT_ID=-100123456789
TELEGRAM_WEBHOOK_SECRET=your-webhook-secret

# CRM SMS marketing (TextUp — textup.uz)
TEXTUP_EMAIL=
TEXTUP_PASSWORD=
# Ixtiyoriy — standart endpoint'larni qayta yozish uchun (odatda bo'sh qoldiriladi)
TEXTUP_LOGIN_URL=
TEXTUP_SMS_URL=
TEXTUP_NICKNAME_ID=

# Tug'ilgan kun SMS tabrigi (matn TextUp shabloniga mos bo'lishi shart)
BIRTHDAY_SMS_TEXT=
BIRTHDAY_SMS_TEMPLATE_ID=

# Buyurtma OTP (telefon tasdig'i). templateId bo'sh bo'lsa — dev-stub (kod log'da,
# DEBUG'da javobda dev_code). TextUp shabloni: resurs nomi + maqsad + {code} bo'lsin.
ORDER_OTP_TEMPLATE_ID=
ORDER_OTP_TEXT=Mayli Restobar (maylirestobar.uz) saytida buyurtmani tasdiqlash uchun kod: {code}
ORDER_OTP_TTL_MINUTES=5
ORDER_OTP_MAX_ATTEMPTS=5

# Bron OTP (telefon tasdig'i). Buyurtma OTP bilan bir xil — alohida shablon/matn.
BOOKING_OTP_TEMPLATE_ID=
BOOKING_OTP_TEXT=Mayli Restobar (maylirestobar.uz) saytida bronni tasdiqlash uchun kod: {code}
BOOKING_OTP_TTL_MINUTES=5
BOOKING_OTP_MAX_ATTEMPTS=5

# Admin'ni yashirish: maxfiy URL (oxirida slash). Dev'da 'admin/' qoldirsa bo'ladi.
ADMIN_URL=admin/
# Dashboard/admin alohida subdomen. Dev'da bo'sh (host ajratish o'chiq).
DASHBOARD_HOST=

YANDEX_MAPS_API_KEY=your-yandex-maps-api-key
