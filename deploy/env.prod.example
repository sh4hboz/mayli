# Production .env namunasi — serverda loyiha ildizidagi `.env` ga ko'chiring.
# DIQQAT: bu fayl git'ga TUSHMASLIGI kerak (.env allaqachon ignore qilingan).

# Kuchli kalit yarating:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
SECRET_KEY=CHANGE_ME_strong_random_key

# prod.py DEBUG=False ni majburlaydi, lekin ANIQLIK uchun:
DEBUG=False

ALLOWED_HOSTS=maylirestobar.uz,www.maylirestobar.uz,manage.maylirestobar.uz
CSRF_TRUSTED_ORIGINS=https://maylirestobar.uz,https://www.maylirestobar.uz,https://manage.maylirestobar.uz

# Dashboard/admin alohida subdomenda. Bo'sh qoldirilsa host ajratish o'chiq.
# To'ldirilsa: ommaviy domende /dashboard/ va admin 404 bo'ladi, faqat shu hostda ochiladi.
DASHBOARD_HOST=manage.maylirestobar.uz

# Admin URL ni maxfiy yo'lga ko'chiring (oxirida slash). Hech kimga oshkor qilmang.
# Yangi tasodifiy yo'l yarating, masalan:
#   python -c "import secrets; print(secrets.token_urlsafe(8).lower().replace('_','')+'-panel/')"
ADMIN_URL=CHANGE_ME-panel/

# Ma'lumotlar bazasi — PostgreSQL tavsiya etiladi (README 1-bo'limga qarang):
DATABASE_URL=postgres://mayli:KUCHLI_PAROL@127.0.0.1:5432/mayli
# Sodda sinov uchun sqlite ham mumkin:
# DATABASE_URL=sqlite:///db.sqlite3

# Redis (cache uchun; o'rnatilgan bo'lsa)
REDIS_URL=redis://127.0.0.1:6379

# Telegram bildirishnomalari
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=CHANGE_ME

# Tashqi xizmatlar (kerak bo'lsa)
YANDEX_MAPS_API_KEY=
